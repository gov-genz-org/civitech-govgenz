# Civitech — variables d'environnement
# Copier ce fichier : cp .env.example .env
# Ne jamais commiter le fichier .env (il est dans .gitignore)

# ── Base de données MySQL ─────────────────────────────────────
DB_HOST=CHANGE_ME
DB_PORT=3306
DB_NAME=CHANGE_ME
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME

# ── Sécurité JWT ──────────────────────────────────────────────
# Générer : openssl rand -hex 32
SECRET_KEY=CHANGE_ME
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Application ───────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Compte admin initial (créé au seed si inexistant) ─────────
ADMIN_EMAIL=admin@civitech.genzgov.org
ADMIN_PASSWORD=CHANGE_ME

# ── Redis (optionnel — l'app fonctionne sans) ─────────────────
REDIS_URL=

# ── Backblaze B2 (upload fichiers) ────────────────────────────
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=civitech
B2_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
B2_PUBLIC_URL=https://f005.backblazeb2.com/file/civitech

# ── Email SMTP (magic link) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=Civitech — GoV Gen Z Madagascar

# ── Frontend build (Docker / Vite) ────────────────────────────
VITE_API_URL=/api
VITE_GA_MEASUREMENT_ID=
